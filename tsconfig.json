{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["dist", "node_modules"]
}
